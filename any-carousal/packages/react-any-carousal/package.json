{
  "name": "react-any-carousel",
  "version": "0.0.1-beta.1",
  "description": "A lightweight, zero-dependency carousel for React. Supports auto-scroll, snap, touch/swipe, custom icons, and any content type.",
  "repository": {
    "type": "git",
    "url": "https://github.com/MayurSMahajan/AnyCarousel"
  },
  "homepage": "https://any-carousel.vercel.app",
  "keywords": [
    "react",
    "carousel",
    "slider",
    "scroll",
    "snap",
    "auto-scroll",
    "lightweight",
    "responsive",
    "touch",
    "swipe",
    "react-carousel",
    "content-carousel"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint . --max-warnings 0",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@turbo/gen": "^2.6.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react-test-renderer": "^19.2.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bezier-easing": "^2.1.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  }
}
